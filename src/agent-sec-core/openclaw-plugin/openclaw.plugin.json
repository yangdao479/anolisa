{
  "id": "agent-sec",
  "name": "Agent Security",
  "version": "0.4.0",
  "description": "Security hooks powered by agent-sec-cli",
  "activation": {
    "onCapabilities": ["hook"]
  },
  "extensions": ["./dist/index.js"],
  "configSchema": {
    "type": "object",
    "properties": {
      "promptScanBlock": {
        "type": "boolean",
        "default": false,
        "description": "检测到 DENY 时直接拦截请求，不转发给 LLM"
      }

    }
  },
  "uiHints": {
    "promptScanBlock": {
      "label": "Prompt 扫描拦截模式",
      "description": "检测到 DENY 时直接拦截请求，不转发给 LLM"
    }

  }
}
